{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentui.example/schemas/agentui-frontmatter.schema.json",
  "title": "Agent UI frontmatter",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "description", "type", "status"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "type": {
      "type": "string",
      "pattern": "^(agent-workbench|conversation-surface|process-surface|task-surface|artifact-surface|evidence-surface|handoff-surface|custom:[a-z0-9][a-z0-9-]*)$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "needs-review", "stale", "disputed", "archived"]
    },
    "profile": {
      "type": "string",
      "enum": ["workbench", "chat-first", "artifact-first", "task-first", "embedded"]
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 2,
      "maxLength": 32
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "maintainers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "scope": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "projectionOnly": { "type": "boolean" },
        "requires": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "metadata": {
      "type": "object"
    },
    "compatibility": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    }
  }
}
